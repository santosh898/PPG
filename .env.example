# =====================================================================
# People's Priorities - environment configuration
# Copy this file to ".env" and fill in the values.
# =====================================================================

# ---- Database: MongoDB Atlas (free M0 tier supports Vector Search) ----
# Create a cluster at https://www.mongodb.com/cloud/atlas and paste the SRV URI.
MONGODB_URI=

# ---- Chat / tool-calling: Hugging Face Inference Providers (OpenAI-compatible) ----
# Create a token with "Inference Providers" permission at
# https://huggingface.co/settings/tokens  (starts with "hf_").
HF_TOKEN=""

# HF OpenAI-compatible router (chat completions + tool calling only).
HF_BASE_URL="https://router.huggingface.co/v1"

# Chat model, pinned to the Groq provider for low, consistent tool-calling
# latency (~0.5-0.9s/call). Must support tool calling.
CHAT_MODEL="openai/gpt-oss-120b:groq"

# ---- Embeddings: HF hosted Inference API (feature-extraction) ----
# multilingual-e5-large -> 1024-dim, matches the Atlas vector indexes.
EMBEDDING_MODEL="intfloat/multilingual-e5-large"
EMBEDDING_DIM="1024"

# ---- Atlas Vector Search ----
# numDimensions must match EMBEDDING_DIM (see docs/atlas-vector-index.json).
ATLAS_VECTOR_INDEX="cluster_vector_index"
