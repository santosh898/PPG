# =====================================================================
# People's Priorities - environment configuration
# Copy this file to ".env" and fill in the values.
# =====================================================================

# ---- Database: MongoDB Atlas (free M0 tier supports Vector Search) ----
# Create a cluster at https://www.mongodb.com/cloud/atlas and paste the SRV URI.
MONGODB_URI=

# ---- Chat / tool-calling + embeddings: Google Gemini API ----
# Free tier is quota-based (RPM/RPD), not a depleting dollar-credit pool.
# Create a key (no billing required) at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Gemini's OpenAI-compatible endpoint (chat completions + tool calling).
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"

# Flash-Lite: built for low-latency, high-frequency agentic/tool-calling
# workloads, and is on the free tier (~15 RPM / ~1000-1500 RPD).
CHAT_MODEL="gemini-2.5-flash-lite"

# ---- Embeddings: Gemini embedding model (native google-genai SDK) ----
# gemini-embedding-001 supports flexible output dims via Matryoshka
# Representation Learning; 768 is Google's recommended balance of quality
# vs. storage. NOTE: only the default 3072-dim output is auto-normalized -
# at 768 dims the app must L2-normalize vectors itself before storing them.
EMBEDDING_MODEL="gemini-embedding-001"
EMBEDDING_DIM="768"

# ---- Atlas Vector Search ----
# numDimensions must match EMBEDDING_DIM (see docs/atlas-vector-index.json).
# Changing EMBEDDING_DIM requires rebuilding the Atlas indexes and
# re-embedding all stored documents (see backend/scripts/embed_guidance.py).
ATLAS_VECTOR_INDEX="cluster_vector_index"
